{
  "name": "vmdhub-monorepo",
  "version": "1.0.0",
  "description": "VMDHub - Cross-platform vendor management and invoice system",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "setup": "pnpm install",
    "build": "turbo build",
    "build:web": "turbo build --filter=@vmd/web",
    "build:desktop": "turbo build --filter=@vmd/desktop",
    "build:mobile": "turbo build --filter=@vmd/mobile",
    "build:shared": "turbo build --filter=@vmd/shared",
    "build:backend": "turbo build --filter=@vmd/backend",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@vmd/web",
    "dev:desktop": "turbo dev --filter=@vmd/desktop",
    "dev:mobile": "turbo dev --filter=@vmd/mobile",
    "dev:backend": "turbo dev --filter=@vmd/backend",
    "start:backend": "turbo start --filter=@vmd/backend",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean; rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "react": "18.2.0",
      "react-dom": "18.2.0"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "core-js",
      "core-js-pure",
      "electron",
      "prisma"
    ]
  }
}
